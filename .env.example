# Pentronix Environment Configuration
# Copy this file to .env and fill in your keys

# ── LLM API Keys ────────────────────────────────────────────
# Primary brain: Groq (free tier available)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Fallback brain: Google Gemini
# Get yours at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── LLM Model Configuration ─────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash

# ── Voice Configuration ──────────────────────────────────────
# Voice for TTS output: en-US-GuyNeural | en-US-JennyNeural
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+10%
TTS_PITCH=+0Hz

# ── Execution Configuration ──────────────────────────────────
# Max time (seconds) allowed for any single tool to run
TOOL_TIMEOUT=300

# ── UI Configuration ─────────────────────────────────────────
# Window position on launch: bottom-right | bottom-left | center
WINDOW_POSITION=bottom-right

# ── Logging ──────────────────────────────────────────────────
# Levels: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=pentronix.log

# ── Database ─────────────────────────────────────────────────
DB_PATH=data/pentronix.db
